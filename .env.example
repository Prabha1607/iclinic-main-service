POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=iclinicdb
POSTGRES_HOST=your_postgres_host
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://your_postgres_user:your_postgres_password@your_postgres_host:5432/iclinicdb

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
ACCESS_SECRET_KEY=your_access_secret_key
REFRESH_SECRET_KEY=your_refresh_secret_key

GROQ_API_KEYS=your_groq_api_keys_comma_separated

TWILIO_SID=your_twilio_sid
TWILIO_AUTH=your_twilio_auth_token
TWILIO_NUMBER=your_twilio_phone_number
MY_PHONE=your_personal_phone_number
PUBLIC_BASE_URL=your_public_base_url_for_webhooks

VOICE=Polly.Joanna
LANGUAGE=en-IN
SPEECH_TIMEOUT=auto
ACTION_ON_EMPTY_RESULT=false
GATHER_TIMEOUT=15

SPEAKING_RATE=medium
SESSION_TTL_SECONDS=1800

EMAIL_USERNAME=your_email_address
EMAIL_PASSWORD=your_email_app_password
EMAIL_FROM=your_email_address
EMAIL_PORT=587
EMAIL_SERVER=smtp.gmail.com
EMAIL_STARTTLS=true
EMAIL_SSL_TLS=false
EMAIL_USE_CREDENTIALS=true

EMERGENCY_FORWARD_NUMBER=your_emergency_forward_number
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid
AUTH_SERVICE_URL=http://your_auth_service_url
